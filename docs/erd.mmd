erDiagram

  Page {
    int page_id PK
    string slug
    string title
    datetime created_at
    datetime updated_at
  }

  Content {
    int content_id PK
    int page_id FK
    int media_asset_id FK
    string type
    text content_en
    text content_ja
    int display_order
    datetime created_at
    datetime updated_at
  }

  MediaAsset {
    int media_asset_id PK
    string file_url
    string file_key
    string file_name
    string file_type
    string alt_text
    datetime created_at
  }

  StaticAsset {
    int static_asset_id PK
    int media_asset_id FK
    string key
    string label
    string asset_type
    text description
    bool is_active
    datetime created_at
    datetime updated_at
  }

  Partner {
    int partner_id PK
    int media_asset_id FK
    string display_name
    string category
    string website_url
    decimal contribution_amount
    int display_order
    bool is_visible
    datetime created_at
    datetime updated_at
  }

  BoardMember {
    int board_member_id PK
    int media_asset_id FK
    string display_name
    string role
    string external_link
    string caption
    date start_date
    int display_order
    datetime created_at
    datetime updated_at
  }

  Event {
    int event_id PK
    int media_asset_id FK
    string title
    text description
    string location
    string calendar_link
    datetime start_datetime
    datetime end_datetime
    bool is_published
    datetime created_at
    datetime updated_at
  }

  VolunteerSlot {
    int volunteer_slot_id PK
    int event_id FK
    string position_name
    text description
    datetime start_datetime
    datetime end_datetime
    int capacity
    int filled_count
    datetime created_at
    datetime updated_at
  }

  VolunteerSignup {
    int volunteer_signup_id PK
    int volunteer_slot_id FK
    string first_name
    string last_name
    string email
    string phone
    text message
    string status
    datetime submitted_at
    datetime reviewed_at
  }

  AdminUser {
    int admin_id PK
    string first_name
    string last_name
    string email
    string password_hash
    bool is_super_admin
    bool is_active
    json permissions
    datetime created_at
    datetime last_login_at
    datetime updated_at
  }

  Donation {
    int donation_id PK
    string donor_first_name
    string donor_last_name
    string donor_email
    decimal amount
    date donation_date
    bool is_anonymous
    text message
    string payment_status
    string reference_id
    datetime created_at
  }

  Membership {
    int membership_id PK
    string first_name
    string last_name
    string email
    string phone
    string membership_type
    decimal amount_paid
    date start_date
    date end_date
    date renewal_date
    string payment_status
    string reference_id
    string status
    text notes
    datetime created_at
    datetime updated_at
  }

  Page ||--o{ Content : "contains"
  Content }o--|| MediaAsset : "has"
  StaticAsset ||--|| MediaAsset : "is"
  Partner }o--|| MediaAsset : "has"
  BoardMember }o--|| MediaAsset : "has"
  Event }o--|| MediaAsset : "has"
  Event ||--o{ VolunteerSlot : "has"
  VolunteerSlot ||--o{ VolunteerSignup : "has"
